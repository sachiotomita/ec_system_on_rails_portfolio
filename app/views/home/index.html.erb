<!-- Hero Section -->
<div class="bg-gradient-to-r from-primary-600 to-primary-800 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <div>
        <h1 class="text-4xl md:text-6xl font-bold mb-6 text-shadow-lg">EC Tomita Portfolio Store</h1>
        <p class="text-xl md:text-2xl mb-4 text-primary-100">Rails 8で構築されたポートフォリオ用ECサイトへようこそ！</p>
        <p class="text-lg mb-8 text-primary-200">最新の技術スタックで作られた、モダンなECシステムをお試しください。</p>
        <%#= link_to products_path, class: "btn-primary btn-lg inline-flex items-center" do %>
          <%#= icon('shopping-cart', size: 12, class_name: "mr-2") %>
<!--          商品を見る-->
        <%# end %>
      </div>
      <div class="text-center lg:text-right">
        <!-- 画像カルーセル -->
        <div class="relative w-full max-w-md mx-auto lg:mx-0">
          <div id="hero-carousel" class="relative overflow-hidden rounded-2xl shadow-2xl">
            <!-- カルーセル画像1: セール情報 -->
            <div class="carousel-slide active">
              <%= link_to products_path, class: "block" do %>
                <div class="bg-gradient-to-br from-red-500 to-pink-600 p-8 text-center hover:from-red-600 hover:to-pink-700 transition-all duration-300">
                  <div class="text-6xl mb-4">🔥</div>
                  <h3 class="text-2xl font-bold mb-2">最大50%OFF</h3>
                  <p class="text-lg opacity-90">期間限定セール開催中！</p>
                  <div class="mt-4">
                    <span class="bg-white text-red-600 px-4 py-2 rounded-full text-sm font-bold hover:bg-red-50 transition-colors">今すぐチェック</span>
                  </div>
                </div>
              <% end %>
            </div>
            
            <!-- カルーセル画像2: 新商品 -->
            <div class="carousel-slide">
              <%= link_to products_path, class: "block" do %>
                <div class="bg-gradient-to-br from-blue-500 to-purple-600 p-8 text-center hover:from-blue-600 hover:to-purple-700 transition-all duration-300">
                  <div class="text-6xl mb-4">✨</div>
                  <h3 class="text-2xl font-bold mb-2">新商品入荷</h3>
                  <p class="text-lg opacity-90">最新トレンドアイテム</p>
                  <div class="mt-4">
                    <span class="bg-white text-blue-600 px-4 py-2 rounded-full text-sm font-bold hover:bg-blue-50 transition-colors">新商品を見る</span>
                  </div>
                </div>
              <% end %>
            </div>
            
            <!-- カルーセル画像3: 無料配送 -->
            <div class="carousel-slide">
              <%= link_to products_path, class: "block" do %>
                <div class="bg-gradient-to-br from-green-500 to-teal-600 p-8 text-center hover:from-green-600 hover:to-teal-700 transition-all duration-300">
                  <div class="text-6xl mb-4">🚚</div>
                  <h3 class="text-2xl font-bold mb-2">無料配送</h3>
                  <p class="text-lg opacity-90">5,000円以上で送料無料</p>
                  <div class="mt-4">
                    <span class="bg-white text-green-600 px-4 py-2 rounded-full text-sm font-bold hover:bg-green-50 transition-colors">条件を確認</span>
                  </div>
                </div>
              <% end %>
            </div>
            
            <!-- カルーセル画像4: 会員特典 -->
            <div class="carousel-slide">
              <%= link_to new_user_registration_path, class: "block" do %>
                <div class="bg-gradient-to-br from-yellow-500 to-orange-600 p-8 text-center hover:from-yellow-600 hover:to-orange-700 transition-all duration-300">
                  <div class="text-6xl mb-4">🎁</div>
                  <h3 class="text-2xl font-bold mb-2">会員特典</h3>
                  <p class="text-lg opacity-90">初回購入10%OFF</p>
                  <div class="mt-4">
                    <span class="bg-white text-yellow-600 px-4 py-2 rounded-full text-sm font-bold hover:bg-yellow-50 transition-colors">会員登録</span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
          
          <!-- カルーセルナビゲーション -->
          <div class="flex justify-center mt-4 space-x-2">
            <button class="carousel-dot active w-3 h-3 rounded-full bg-white bg-opacity-50 hover:bg-opacity-75 transition-all" data-slide="0"></button>
            <button class="carousel-dot w-3 h-3 rounded-full bg-white bg-opacity-50 hover:bg-opacity-75 transition-all" data-slide="1"></button>
            <button class="carousel-dot w-3 h-3 rounded-full bg-white bg-opacity-50 hover:bg-opacity-75 transition-all" data-slide="2"></button>
            <button class="carousel-dot w-3 h-3 rounded-full bg-white bg-opacity-50 hover:bg-opacity-75 transition-all" data-slide="3"></button>
          </div>
          
          <!-- 前へ/次へボタン -->
          <button id="prev-btn" class="absolute left-2 top-1/2 transform -translate-y-1/2 bg-white bg-opacity-20 hover:bg-opacity-30 text-white p-2 rounded-full transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          <button id="next-btn" class="absolute right-2 top-1/2 transform -translate-y-1/2 bg-white bg-opacity-20 hover:bg-opacity-30 text-white p-2 rounded-full transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Featured Products Section -->
  <% if @featured_products.any? %>
    <div class="mb-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4 flex items-center justify-center">
          <%= icon('star', size: 12, class_name: "text-yellow-500 mr-3") %>
          おすすめ商品
        </h2>
        <p class="text-lg text-gray-600">厳選された人気商品をご紹介します</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% @featured_products.each do |product| %>
          <div class="card group hover:shadow-xl transition-shadow duration-300">
            <div class="relative overflow-hidden rounded-t-lg">
              <% if product.primary_image %>
                <%= image_tag product.primary_image.image, class: "w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300" %>
              <% else %>
                <div class="w-full h-48 bg-gray-100 flex items-center justify-center">
                  <span class="text-gray-400">画像なし</span>
                </div>
              <% end %>
              <div class="absolute top-4 right-4">
                <span class="badge-primary">おすすめ</span>
              </div>
            </div>
            
            <div class="card-body">
              <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2"><%= product.name %></h3>
              <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= product.short_description&.truncate(100) %></p>
              
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center space-x-2">
                  <% if product.on_sale? %>
                    <span class="text-sm text-gray-500 line-through">¥<%= number_with_delimiter(product.price, precision: 0) %></span>
                    <span class="text-lg font-bold text-red-600">¥<%= number_with_delimiter(product.sale_price, precision: 0) %></span>
                  <% else %>
                    <span class="text-lg font-bold text-gray-900">¥<%= number_with_delimiter(product.price, precision: 0) %></span>
                  <% end %>
                </div>
              </div>
              
              <div class="space-y-2">
                <%= link_to product_path(product), class: "btn-outline btn-sm w-full flex items-center justify-center" do %>
                  <%= icon('eye', size: 16, class_name: "mr-2 w-4 h-4") %>
                  詳細を見る
                <% end %>
                
                <% if product.in_stock? %>
                  <button onclick="addToCart(<%= product.id %>)" class="btn-primary btn-sm w-full flex items-center justify-center">
                    <%= icon('shopping-cart', size: 16, class_name: "mr-2 w-4 h-4") %>
                    カートに追加
                  </button>
                <% else %>
                  <button class="btn-secondary btn-sm w-full flex items-center justify-center" disabled>
                    <%= icon('x-mark', size: 16, class_name: "mr-2 w-4 h-4") %>
                    在庫切れ
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      
      <div class="text-center mt-12">
        <%= link_to products_path, class: "btn-outline btn-lg" do %>
          すべての商品を見る
          <%= icon('arrow-right', size: 12, class_name: "ml-2") %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Categories Section -->
  <% if @categories.any? %>
    <div class="mb-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4 flex items-center justify-center">
          <%= icon('tag', size: 12, class_name: "text-primary-600 mr-3") %>
          カテゴリ
        </h2>
        <p class="text-lg text-gray-600">商品カテゴリから探す</p>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6">
        <% @categories.each do |category| %>
          <%= link_to products_path(category_id: category.id), class: "group" do %>
            <div class="card text-center group-hover:shadow-lg transition-all duration-300 group-hover:-translate-y-1">
              <div class="card-body py-8">
                <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-primary-200 transition-colors">
                  <%= icon('tag', size: 12, class_name: "text-primary-600") %>
                </div>
                <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors"><%= category.name %></h3>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Recent Products Section -->
  <% if @recent_products.any? %>
    <div class="mb-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4 flex items-center justify-center">
          <%= icon('clock', size: 12, class_name: "text-green-500 mr-3") %>
          新着商品
        </h2>
        <p class="text-lg text-gray-600">最新の商品をご紹介します</p>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6">
        <% @recent_products.each do |product| %>
          <div class="card group hover:shadow-lg transition-all duration-300 group-hover:-translate-y-1">
            <div class="relative overflow-hidden rounded-t-lg">
              <% if product.primary_image %>
                <%= image_tag product.primary_image.image, class: "w-full h-32 object-cover group-hover:scale-105 transition-transform duration-300" %>
              <% else %>
                <div class="w-full h-32 bg-gray-100 flex items-center justify-center">
                  <span class="text-gray-400 text-xs">画像なし</span>
                </div>
              <% end %>
            </div>
            
            <div class="card-body p-4">
              <h3 class="text-sm font-semibold text-gray-900 mb-2 line-clamp-2"><%= product.name.truncate(30) %></h3>
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-bold text-gray-900">¥<%= number_with_delimiter(product.current_price, precision: 0) %></span>
                <span class="text-xs text-gray-500"><%= product.category.name %></span>
              </div>
              <%= link_to product_path(product), class: "btn-outline btn-sm w-full flex items-center justify-center" do %>
                <%= icon('eye', size: 6, class_name: "mr-1 w-1.5 h-1.5") %>
                詳細
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Newsletter Subscription Section -->
  <div class="bg-gradient-to-r from-primary-600 to-primary-800 rounded-2xl p-8 md:p-12 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <div class="mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white bg-opacity-20 rounded-full mb-6">
          <%= icon('envelope', size: 12, class_name: "text-white") %>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">最新情報をお届け</h2>
        <p class="text-lg md:text-xl text-primary-100 mb-2">新商品の情報やお得なキャンペーンをいち早くお知らせします</p>
        <p class="text-primary-200">メルマガ登録で、初回購入時に使える10%オフクーポンをプレゼント！</p>
      </div>
      
      <div class="max-w-md mx-auto">
        <%= form_with url: "#", method: :post, local: true, class: "flex flex-col sm:flex-row gap-4" do |f| %>
          <%= f.email_field :email, placeholder: "メールアドレスを入力", 
                class: "flex-1 px-4 py-3 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50" %>
          <%= f.submit "登録する", 
                class: "bg-white text-primary-600 hover:bg-primary-50 px-8 py-3 rounded-lg font-semibold transition-colors duration-200 flex items-center justify-center" %>
        <% end %>
        
        <p class="text-sm text-primary-200 mt-4">
          登録は無料です。いつでも配信停止できます。
        </p>
      </div>
      
      <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-primary-200">
        <div class="flex items-center">
          <%= icon('check', size: 6, class_name: "mr-2") %>
          新商品情報
        </div>
        <div class="flex items-center">
          <%= icon('check', size: 6, class_name: "mr-2") %>
          特別キャンペーン
        </div>
        <div class="flex items-center">
          <%= icon('check', size: 6, class_name: "mr-2") %>
          お得なクーポン
        </div>
      </div>
    </div>
  </div>
</div>
