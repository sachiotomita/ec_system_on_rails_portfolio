<!-- Hero Section -->
<div class="jumbotron bg-primary text-white rounded-3 p-5 mb-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold">EC Portfolio Store</h1>
        <p class="lead">Rails 8で構築されたポートフォリオ用ECサイトへようこそ！</p>
        <p>最新の技術スタックで作られた、モダンなECシステムをお試しください。</p>
        <%= link_to "商品を見る", products_path, class: "btn btn-light btn-lg" %>
      </div>
      <div class="col-lg-6 text-center">
        <i class="bi bi-shop display-1 opacity-50"></i>
      </div>
    </div>
  </div>
</div>

<div class="container">
  <!-- Featured Products Section -->
  <% if @featured_products.any? %>
    <div class="row mb-5">
      <div class="col-12">
        <h2 class="mb-4">
          <i class="bi bi-star-fill text-warning me-2"></i>おすすめ商品
        </h2>
        <div class="row">
          <% @featured_products.each do |product| %>
            <div class="col-lg-3 col-md-6 mb-4">
              <div class="card h-100 border-0 shadow-sm">
                <% if product.primary_image %>
                  <%= image_tag product.primary_image.image, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
                <% else %>
                  <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                    <span class="text-muted">画像なし</span>
                  </div>
                <% end %>
                
                <div class="card-body d-flex flex-column">
                  <h5 class="card-title"><%= product.name %></h5>
                  <p class="card-text text-muted small"><%= product.short_description&.truncate(100) %></p>
                  
                  <div class="mt-auto">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div>
                        <% if product.on_sale? %>
                          <span class="text-decoration-line-through text-muted">¥<%= number_with_delimiter(product.price) %></span>
                          <span class="text-danger fw-bold">¥<%= number_with_delimiter(product.sale_price) %></span>
                        <% else %>
                          <span class="fw-bold">¥<%= number_with_delimiter(product.price) %></span>
                        <% end %>
                      </div>
                      <span class="badge bg-warning text-dark">おすすめ</span>
                    </div>
                    
                    <div class="d-grid gap-2">
                      <%= link_to product_path(product), class: "btn btn-outline-primary btn-sm" do %>
                        <i class="bi bi-eye me-1"></i>詳細を見る
                      <% end %>
                      <% if product.in_stock? %>
                        <%= form_with url: cart_add_item_path, method: :post, local: true, class: "d-inline" do |f| %>
                          <%= f.hidden_field :product_id, value: product.id %>
                          <%= f.hidden_field :quantity, value: 1 %>
                          <%= f.submit "カートに追加", class: "btn btn-primary btn-sm" do %>
                            <i class="bi bi-cart-plus me-1"></i>カートに追加
                          <% end %>
                        <% end %>
                      <% else %>
                        <button class="btn btn-secondary btn-sm" disabled>
                          <i class="bi bi-x-circle me-1"></i>在庫切れ
                        </button>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div class="text-center">
          <%= link_to "すべての商品を見る", products_path, class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Categories Section -->
  <% if @categories.any? %>
    <div class="row mb-5">
      <div class="col-12">
        <h2 class="mb-4">
          <i class="bi bi-tags me-2"></i>カテゴリ
        </h2>
        <div class="row">
          <% @categories.each do |category| %>
            <div class="col-lg-2 col-md-4 col-sm-6 mb-3">
              <%= link_to products_path(category_id: category.id), class: "text-decoration-none" do %>
                <div class="card h-100 text-center border-0 shadow-sm hover-shadow">
                  <div class="card-body">
                    <i class="bi bi-tag display-4 text-primary mb-2"></i>
                    <h6 class="card-title"><%= category.name %></h6>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Recent Products Section -->
  <% if @recent_products.any? %>
    <div class="row mb-5">
      <div class="col-12">
        <h2 class="mb-4">
          <i class="bi bi-clock me-2"></i>新着商品
        </h2>
        <div class="row">
          <% @recent_products.each do |product| %>
            <div class="col-lg-2 col-md-4 col-sm-6 mb-4">
              <div class="card h-100 border-0 shadow-sm">
                <% if product.primary_image %>
                  <%= image_tag product.primary_image.image, class: "card-img-top", style: "height: 150px; object-fit: cover;" %>
                <% else %>
                  <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 150px;">
                    <span class="text-muted small">画像なし</span>
                  </div>
                <% end %>
                
                <div class="card-body d-flex flex-column p-2">
                  <h6 class="card-title small"><%= product.name.truncate(30) %></h6>
                  <div class="mt-auto">
                    <div class="d-flex justify-content-between align-items-center">
                      <span class="fw-bold small">¥<%= number_with_delimiter(product.current_price) %></span>
                      <small class="text-muted"><%= product.category.name %></small>
                    </div>
                    <%= link_to product_path(product), class: "btn btn-outline-primary btn-sm w-100 mt-2" do %>
                      <i class="bi bi-eye me-1"></i>詳細
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
