<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Product Image -->
    <div>
      <% if @product.primary_image %>
        <%= image_tag @product.primary_image.image, class: "w-full h-96 object-cover rounded-lg shadow-lg" %>
      <% else %>
        <div class="w-full h-96 bg-gray-100 flex items-center justify-center rounded-lg">
          <span class="text-gray-400 text-2xl">画像なし</span>
        </div>
      <% end %>
    </div>
    
    <!-- Product Details -->
    <div class="space-y-6">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @product.name %></h1>
        <p class="text-gray-600 text-lg"><%= @product.category.name %></p>
      </div>
      
      <div class="flex items-center space-x-4">
        <% if @product.on_sale? %>
          <div class="flex items-center space-x-2">
            <span class="text-xl text-gray-500 line-through">¥<%= number_with_delimiter(@product.price, precision: 0) %></span>
            <span class="text-3xl font-bold text-red-600">¥<%= number_with_delimiter(@product.sale_price, precision: 0) %></span>
          </div>
          <span class="badge-danger">セール中</span>
        <% else %>
          <span class="text-3xl font-bold text-gray-900">¥<%= number_with_delimiter(@product.price, precision: 0) %></span>
        <% end %>
      </div>
      
      <!-- レビュー評価表示 -->
      <div class="flex items-center space-x-4">
        <div class="flex items-center space-x-2">
          <div class="flex text-yellow-400">
            <% 5.times do |i| %>
              <% if i < @product.average_rating %>
                <span>★</span>
              <% else %>
                <span class="text-gray-300">☆</span>
              <% end %>
            <% end %>
          </div>
          <span class="text-sm text-gray-600">
            <%= @product.average_rating %> (<%= @product.review_count %>件のレビュー)
          </span>
        </div>
      </div>
      
      <div>
        <span class="badge-<%= @product.in_stock? ? 'success' : 'danger' %> text-lg">
          <%= @product.in_stock? ? "在庫あり (#{@product.stock_quantity}個)" : "在庫切れ" %>
        </span>
      </div>
      
      <div class="prose max-w-none">
        <h3 class="text-xl font-semibold text-gray-900 mb-3">商品説明</h3>
        <div class="text-gray-700 leading-relaxed">
          <%= simple_format(@product.description) %>
        </div>
      </div>
      
      <% if @product.in_stock? %>
        <div class="space-y-4">
          <div class="flex items-end space-x-4">
            <div class="flex-1">
              <label for="quantity" class="form-label">数量</label>
              <input type="number" id="quantity" value="1" min="1" max="<%= @product.stock_quantity %>" class="form-input">
            </div>
            <div class="flex-1">
              <button onclick="addToCart(<%= @product.id %>, document.getElementById('quantity').value)" class="btn-primary btn-lg w-full flex items-center justify-center">
                <%= icon('shopping-cart', size: 9, class_name: "mr-2 w-5 h-5") %>
                カートに追加
              </button>
            </div>
          </div>
        </div>
      <% else %>
        <button class="btn-secondary btn-lg w-full flex items-center justify-center" disabled>
          <%= icon('x-mark', size: 9, class_name: "mr-2 w-5 h-5") %>
          在庫切れのため購入できません
        </button>
      <% end %>
    </div>
  </div>
</div>

<!-- Related Products -->
<% if @related_products.any? %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h3 class="text-2xl font-bold text-gray-900 mb-8">関連商品</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @related_products.each do |product| %>
        <div class="card group hover:shadow-xl transition-shadow duration-300">
          <div class="relative overflow-hidden rounded-t-lg">
            <% if product.primary_image %>
              <%= image_tag product.primary_image.image, class: "w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300" %>
            <% else %>
              <div class="w-full h-48 bg-gray-100 flex items-center justify-center">
                <span class="text-gray-400">画像なし</span>
              </div>
            <% end %>
          </div>
          
          <div class="card-body">
            <h4 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2"><%= product.name %></h4>
            <div class="flex items-center justify-between mb-4">
              <span class="text-lg font-bold text-gray-900">¥<%= number_with_delimiter(product.current_price, precision: 0) %></span>
              <span class="text-xs text-gray-500">在庫: <%= product.stock_quantity %></span>
            </div>
            <%= link_to product_path(product), class: "btn-outline btn-sm w-full flex items-center justify-center" do %>
              <%= icon('eye', size: 16, class_name: "mr-2 w-4 h-4") %>
              詳細を見る
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- レビューセクション -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- レビュー一覧 -->
    <div class="lg:col-span-2">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-2xl font-bold text-gray-900">レビュー</h3>
        <span class="text-sm text-gray-600"><%= @product.review_count %>件のレビュー</span>
      </div>
      
      <% if @product.reviews.any? %>
        <div class="space-y-6">
          <% @product.reviews.recent.limit(10).each do |review| %>
            <div class="border-b border-gray-200 pb-6">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center space-x-2">
                  <span class="font-semibold text-gray-900"><%= review.user.full_name %></span>
                  <div class="flex text-yellow-400">
                    <% 5.times do |i| %>
                      <% if i < review.rating %>
                        <span>★</span>
                      <% else %>
                        <span class="text-gray-300">☆</span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
                <span class="text-sm text-gray-500"><%= review.created_at.strftime("%Y年%m月%d日") %></span>
              </div>
              <h4 class="font-semibold text-gray-900 mb-2"><%= review.title %></h4>
              <p class="text-gray-700 leading-relaxed"><%= simple_format(review.content) %></p>
              
              <% if user_signed_in? && review.can_be_edited_by?(current_user) %>
                <div class="mt-3 flex space-x-2">
                  <%= link_to edit_product_review_path(@product, review), class: "text-sm text-blue-600 hover:text-blue-800" do %>
                    編集
                  <% end %>
                  <%= link_to product_review_path(@product, review), method: :delete, 
                              class: "text-sm text-red-600 hover:text-red-800",
                              data: { confirm: "このレビューを削除しますか？" } do %>
                    削除
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-gray-500">まだレビューがありません。</p>
        </div>
      <% end %>
    </div>
    
    <!-- レビュー投稿フォーム -->
    <div class="lg:col-span-1">
      <% if user_signed_in? %>
        <% if @product.can_be_reviewed_by?(current_user) %>
          <div class="card">
            <div class="card-header">
              <h4 class="text-lg font-semibold text-gray-900">レビューを投稿</h4>
            </div>
            <div class="card-body">
              <%= form_with model: [@product, @product.reviews.build], local: true, class: "space-y-4" do |f| %>
                <div>
                  <%= f.label :rating, "評価", class: "form-label" %>
                  <div class="flex space-x-1">
                    <% 5.times do |i| %>
                      <%= f.radio_button :rating, i + 1, class: "sr-only peer" %>
                      <label for="<%= "review_rating_#{i + 1}" %>" class="text-2xl text-gray-300 cursor-pointer peer-checked:text-yellow-400 hover:text-yellow-400">
                        ★
                      </label>
                    <% end %>
                  </div>
                </div>
                
                <div>
                  <%= f.label :title, "タイトル", class: "form-label" %>
                  <%= f.text_field :title, class: "form-input", placeholder: "レビューのタイトルを入力" %>
                </div>
                
                <div>
                  <%= f.label :content, "レビュー内容", class: "form-label" %>
                  <%= f.text_area :content, class: "form-input", rows: 4, placeholder: "商品の感想をお聞かせください" %>
                </div>
                
                <div class="flex space-x-2">
                  <%= f.submit "レビューを投稿", class: "btn-primary flex-1" %>
                </div>
              <% end %>
            </div>
          </div>
        <% elsif @product.has_review_from?(current_user) %>
          <div class="card">
            <div class="card-body text-center">
              <p class="text-gray-600">あなたは既にこの商品のレビューを投稿しています。</p>
            </div>
          </div>
        <% else %>
          <div class="card">
            <div class="card-body text-center">
              <p class="text-gray-600">レビューを投稿するには、この商品を購入する必要があります。</p>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="card">
          <div class="card-body text-center">
            <p class="text-gray-600 mb-4">レビューを投稿するにはログインが必要です。</p>
            <%= link_to "ログイン", new_user_session_path, class: "btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
