<div class="row">
  <div class="col-md-6">
    <% if @product.primary_image %>
      <%= image_tag @product.primary_image.image, class: "img-fluid rounded" %>
    <% else %>
      <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 400px;">
        <span class="text-muted fs-4">画像なし</span>
      </div>
    <% end %>
  </div>
  
  <div class="col-md-6">
    <h1><%= @product.name %></h1>
    <p class="text-muted"><%= @product.category.name %></p>
    
    <div class="mb-3">
      <% if @product.on_sale? %>
        <span class="text-decoration-line-through text-muted fs-5">¥<%= number_with_delimiter(@product.price) %></span>
        <span class="text-danger fw-bold fs-4">¥<%= number_with_delimiter(@product.sale_price) %></span>
        <span class="badge bg-danger ms-2">セール中</span>
      <% else %>
        <span class="fw-bold fs-4">¥<%= number_with_delimiter(@product.price) %></span>
      <% end %>
    </div>
    
    <div class="mb-3">
      <span class="badge bg-<%= @product.in_stock? ? 'success' : 'danger' %>">
        <%= @product.in_stock? ? "在庫あり (#{@product.stock_quantity}個)" : "在庫切れ" %>
      </span>
    </div>
    
    <div class="mb-4">
      <h5>商品説明</h5>
      <p><%= simple_format(@product.description) %></p>
    </div>
    
    <% if @product.in_stock? %>
      <%= form_with url: cart_add_item_path, method: :post, local: true, class: "mb-4" do |f| %>
        <div class="row">
          <div class="col-4">
            <%= f.label :quantity, "数量", class: "form-label" %>
            <%= f.number_field :quantity, value: 1, min: 1, max: @product.stock_quantity, class: "form-control" %>
          </div>
          <div class="col-8 d-flex align-items-end">
            <%= f.hidden_field :product_id, value: @product.id %>
            <%= f.submit "カートに追加", class: "btn btn-primary btn-lg" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <button class="btn btn-secondary btn-lg" disabled>在庫切れのため購入できません</button>
    <% end %>
  </div>
</div>

<!-- Related Products -->
<% if @related_products.any? %>
  <div class="row mt-5">
    <div class="col-12">
      <h3>関連商品</h3>
      <div class="row">
        <% @related_products.each do |product| %>
          <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
            <div class="card h-100">
              <% if product.primary_image %>
                <%= image_tag product.primary_image.image, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
              <% else %>
                <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                  <span class="text-muted">画像なし</span>
                </div>
              <% end %>
              
              <div class="card-body d-flex flex-column">
                <h6 class="card-title"><%= product.name %></h6>
                <div class="mt-auto">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-bold">¥<%= number_with_delimiter(product.current_price) %></span>
                    <small class="text-muted">在庫: <%= product.stock_quantity %></small>
                  </div>
                  <%= link_to "詳細を見る", product_path(product), class: "btn btn-outline-primary btn-sm" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
