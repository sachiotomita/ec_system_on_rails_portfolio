<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">商品一覧</h1>
    
    <!-- Search and Filter -->
    <div class="mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= form_with url: products_path, method: :get, local: true, class: "flex space-x-2" do |f| %>
            <%= f.text_field :search, placeholder: "商品名で検索...", value: params[:search], class: "form-input flex-1" %>
            <%= f.submit "検索", class: "btn-outline" %>
        <% end %>
      </div>
        <div>
          <%= form_with url: products_path, method: :get, local: true, class: "flex space-x-2" do |f| %>
          <%= f.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]), 
                         { prompt: "カテゴリで絞り込み" }, { class: "form-input flex-1" } %>
            <%= f.submit "絞り込み", class: "btn-secondary" %>
        <% end %>
        </div>
      </div>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <% @products.each do |product| %>
        <div class="card group hover:shadow-xl transition-shadow duration-300">
          <div class="relative overflow-hidden rounded-t-lg">
            <% if product.primary_image %>
              <%= image_tag product.primary_image.image, class: "w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300" %>
            <% else %>
              <div class="w-full h-48 bg-gray-100 flex items-center justify-center">
                <span class="text-gray-400">画像なし</span>
              </div>
            <% end %>
          </div>
          
          <div class="card-body">
            <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2"><%= product.name %></h3>
            <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= product.short_description&.truncate(100) %></p>
            
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                    <% if product.on_sale? %>
                  <span class="text-sm text-gray-500 line-through">¥<%= number_with_delimiter(product.price) %></span>
                  <span class="text-lg font-bold text-red-600">¥<%= number_with_delimiter(product.sale_price) %></span>
                    <% else %>
                  <span class="text-lg font-bold text-gray-900">¥<%= number_with_delimiter(product.price) %></span>
                    <% end %>
                  </div>
              <span class="text-xs text-gray-500">在庫: <%= product.stock_quantity %></span>
                </div>
                
            <div class="space-y-2">
              <%= link_to product_path(product), class: "btn-outline btn-sm w-full flex items-center justify-center" do %>
                <%= icon('eye', size: 16, class_name: "mr-2 w-4 h-4") %>
                詳細を見る
                  <% end %>
              
                  <% if product.in_stock? %>
                <button onclick="addToCart(<%= product.id %>)" class="btn-primary btn-sm w-full flex items-center justify-center">
                  <%= icon('shopping-cart', size: 16, class_name: "mr-2 w-4 h-4") %>
                  カートに追加
                </button>
                  <% else %>
                <button class="btn-secondary btn-sm w-full flex items-center justify-center" disabled>
                  <%= icon('x-mark', size: 16, class_name: "mr-2 w-4 h-4") %>
                  在庫切れ
                    </button>
                  <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
</div>
