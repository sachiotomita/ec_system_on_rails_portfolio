<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "管理画面 - EC Tomita Portfolio Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <!-- Admin Navigation -->
    <nav class="bg-gray-900 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to admin_root_path, class: "text-white text-xl font-bold hover:text-gray-300 transition-colors" do %>
                管理画面
              <% end %>
            </div>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
              <%= link_to admin_root_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('cog-6-tooth', size: 10, class_name: "mr-2") %>
                ダッシュボード
              <% end %>
              <div class="relative">
                <button class="text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center" onclick="toggleDropdown('productsDropdown')">
                  <%= icon('home', size: 10, class_name: "mr-2") %>
                  商品管理
                  <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div id="productsDropdown" class="hidden absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50">
                  <%= link_to admin_products_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    商品一覧
                  <% end %>
                  <%= link_to new_admin_product_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    商品登録
                  <% end %>
                  <div class="border-t border-gray-100"></div>
                  <%= link_to admin_categories_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    カテゴリ一覧
                  <% end %>
                  <%= link_to new_admin_category_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    カテゴリ登録
                  <% end %>
                </div>
              </div>
              <%= link_to admin_orders_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('user', size: 10, class_name: "mr-2") %>
                注文管理
              <% end %>
            </div>
          </div>
          
          <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-4">
            <%= link_to root_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
              <%= icon('shopping-cart', size: 10, class_name: "mr-2") %>
              ストアフロント
            <% end %>
            <div class="relative">
              <button class="text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center" onclick="toggleDropdown('userDropdown')">
                <%= icon('user', size: 10, class_name: "mr-2") %>
                <%= current_user.full_name %>
                <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              <div id="userDropdown" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50">
                <%= link_to edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                  プロフィール
                <% end %>
                <div class="border-t border-gray-100"></div>
                <%= link_to destroy_user_session_path, method: :delete, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                  ログアウト
                <% end %>
              </div>
            </div>
          </div>
          
          <!-- Mobile menu button -->
          <div class="sm:hidden flex items-center">
            <button class="text-gray-300 hover:text-white p-2" onclick="toggleMobileMenu()">
              <%= icon('bars-3', size: 10) %>
            </button>
          </div>
        </div>
        
        <!-- Mobile menu -->
        <div id="mobileMenu" class="hidden sm:hidden">
          <div class="pt-2 pb-3 space-y-1">
            <%= link_to admin_root_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('cog-6-tooth', size: 10, class_name: "mr-2") %>
              ダッシュボード
            <% end %>
            <%= link_to admin_products_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('home', size: 10, class_name: "mr-2") %>
              商品管理
            <% end %>
            <%= link_to admin_orders_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('user', size: 10, class_name: "mr-2") %>
              注文管理
            <% end %>
          </div>
          <div class="pt-4 pb-3 border-t border-gray-700">
            <%= link_to root_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('shopping-cart', size: 10, class_name: "mr-2") %>
              ストアフロント
            <% end %>
            <div class="px-3 py-2 text-base font-medium text-white">
              <%= current_user.full_name %>
            </div>
            <div class="mt-3 space-y-1">
              <%= link_to edit_user_registration_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium" do %>
                プロフィール
              <% end %>
              <%= link_to destroy_user_session_path, method: :delete, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium" do %>
                ログアウト
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 flex items-center justify-between" role="alert">
        <div class="flex items-center">
          <%= icon('check', size: 10, class_name: "mr-2") %>
          <%= notice %>
        </div>
        <button type="button" class="text-green-400 hover:text-green-600" onclick="this.parentElement.style.display='none'">
          <%= icon('x-mark', size: 10) %>
        </button>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 flex items-center justify-between" role="alert">
        <div class="flex items-center">
          <%= icon('exclamation-triangle', size: 10, class_name: "mr-2") %>
          <%= alert %>
        </div>
        <button type="button" class="text-red-400 hover:text-red-600" onclick="this.parentElement.style.display='none'">
          <%= icon('x-mark', size: 10) %>
        </button>
      </div>
    <% end %>

    <!-- Main Content -->
    <div class="flex">
      <!-- Sidebar -->
      <nav class="hidden md:block w-64 bg-white shadow-lg min-h-screen">
        <div class="p-6">
          <ul class="space-y-2">
            <li>
              <%= link_to admin_root_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-md #{'bg-primary-100 text-primary-700' if current_page?(admin_root_path)} #{'text-gray-700 hover:bg-gray-100' unless current_page?(admin_root_path)}" do %>
                <%= icon('cog-6-tooth', size: 10, class_name: "mr-3") %>
                ダッシュボード
              <% end %>
            </li>
            <li>
              <%= link_to admin_products_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-md #{'bg-primary-100 text-primary-700' if controller_name == 'products'}" do %>
                <%= icon('home', size: 10, class_name: "mr-3") %>
                商品管理
              <% end %>
            </li>
            <li>
              <%= link_to admin_categories_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-md #{'bg-primary-100 text-primary-700' if controller_name == 'categories'}" do %>
                <%= icon('tag', size: 10, class_name: "mr-3") %>
                カテゴリ管理
              <% end %>
            </li>
            <li>
              <%= link_to admin_orders_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-md #{'bg-primary-100 text-primary-700' if controller_name == 'orders'}" do %>
                <%= icon('user', size: 10, class_name: "mr-3") %>
                注文管理
              <% end %>
            </li>
          </ul>
        </div>
      </nav>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <div class="flex justify-between items-center mb-8 pb-4 border-b border-gray-200">
          <h1 class="text-3xl font-bold text-gray-900"><%= content_for(:page_title) || controller_name.humanize %></h1>
          <div class="flex space-x-2">
            <%= yield :page_actions %>
          </div>
        </div>
        
        <%= yield %>
      </main>
    </div>

    <script>
      function toggleDropdown(dropdownId) {
        const dropdown = document.getElementById(dropdownId);
        dropdown.classList.toggle('hidden');
      }

      function toggleMobileMenu() {
        const menu = document.getElementById('mobileMenu');
        menu.classList.toggle('hidden');
      }

      // Close dropdown when clicking outside
      document.addEventListener('click', function(event) {
        const dropdowns = ['userDropdown', 'productsDropdown'];
        dropdowns.forEach(dropdownId => {
          const dropdown = document.getElementById(dropdownId);
          const button = event.target.closest('button');
          if (dropdown && !dropdown.contains(event.target) && !button) {
            dropdown.classList.add('hidden');
          }
        });
      });
    </script>
  </body>
</html>