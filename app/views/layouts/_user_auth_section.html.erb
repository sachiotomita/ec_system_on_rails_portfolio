<!-- User Authentication Section -->
<% if user_signed_in? %>
  <div class="relative">
    <button class="<%= local_assigns[:button_class] || 'text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center' %>" onclick="toggleDropdown()">
      <%= icon('user', size: local_assigns[:icon_size] || 10, class_name: "mr-2") if local_assigns[:show_icon] %>
      <%= current_user.full_name %>
      <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>
    <div id="userDropdown" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50">
      <%= link_to orders_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
        注文履歴
      <% end %>
      <%= link_to edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
        プロフィール
      <% end %>
      <% if current_user.admin? %>
        <div class="border-t border-gray-100"></div>
        <%= link_to admin_root_path, class: "block px-4 py-2 text-sm text-yellow-600 hover:bg-gray-100" do %>
          管理画面
        <% end %>
      <% end %>
      <div class="border-t border-gray-100"></div>
      <%= link_to destroy_user_session_path, method: :delete, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
        ログアウト
      <% end %>
    </div>
  </div>
<% else %>
  <%= link_to "ログイン", new_user_session_path, class: local_assigns[:login_class] || "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
  <%= link_to "新規登録", new_user_registration_path, class: local_assigns[:register_class] || "bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors" %>
<% end %>
