<!-- Flash Messages -->
<% if notice %>
  <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-md mx-4 mt-4 flex items-center justify-between" role="alert">
    <div class="flex items-center">
      <%= icon('check', size: 12, class_name: "mr-2") %>
      <%= notice %>
    </div>
    <button type="button" class="text-green-400 hover:text-green-600" onclick="this.parentElement.style.display='none'">
      <%= icon('x-mark', size: 12) %>
    </button>
  </div>
<% end %>

<% if alert %>
  <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md mx-4 mt-4 flex items-center justify-between" role="alert">
    <div class="flex items-center">
      <%= icon('exclamation-triangle', size: 12, class_name: "mr-2") %>
      <%= alert %>
    </div>
    <button type="button" class="text-red-400 hover:text-red-600" onclick="this.parentElement.style.display='none'">
      <%= icon('x-mark', size: 12) %>
    </button>
  </div>
<% end %>
