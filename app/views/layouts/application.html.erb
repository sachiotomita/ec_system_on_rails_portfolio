<!DOCTYPE html>
<html>
  <%= render 'layouts/head' %>

  <body>
    <!-- Navigation -->
    <nav class="bg-gray-900 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to root_path, class: "text-white text-xl font-bold hover:text-gray-300 transition-colors" do %>
                EC Tomita Portfolio Store
              <% end %>
            </div>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
              <%= link_to products_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('home', size: 12, class_name: "mr-2") %>
                商品一覧
              <% end %>
              <%= link_to cart_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('shopping-cart', size: 12, class_name: "mr-2") %>
                カート
              <% end %>
              <%= link_to orders_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('user', size: 12, class_name: "mr-2") %>
                注文履歴
              <% end %>
            </div>
          </div>
          
          <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-4">
            <%= render 'layouts/user_auth_section' %>
          </div>
          
          <!-- Mobile menu button -->
          <div class="sm:hidden flex items-center">
            <button class="text-gray-300 hover:text-white p-2" onclick="toggleMobileMenu()">
              <%= icon('bars-3', size: 12) %>
            </button>
          </div>
        </div>
        
        <!-- Mobile menu -->
        <div id="mobileMenu" class="hidden sm:hidden">
          <div class="pt-2 pb-3 space-y-1">
            <%= link_to products_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('home', size: 12, class_name: "mr-2") %>
              商品一覧
            <% end %>
            <%= link_to cart_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('shopping-cart', size: 12, class_name: "mr-2") %>
              カート
            <% end %>
            <%= link_to orders_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('user', size: 12, class_name: "mr-2") %>
              注文履歴
            <% end %>
          </div>
          <div class="pt-4 pb-3 border-t border-gray-700">
            <%= render 'layouts/mobile_user_auth_section' %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <%= render 'layouts/flash_messages' %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <!-- Footer -->
    <%= render 'layouts/footer' %>

    <%= render 'layouts/common_scripts' %>
  </body>
</html>
