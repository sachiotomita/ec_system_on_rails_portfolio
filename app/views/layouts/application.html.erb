<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ec Fullscratch On Rails Portfolio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- Navigation -->
    <nav class="bg-gray-900 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to root_path, class: "text-white text-xl font-bold hover:text-gray-300 transition-colors" do %>
                EC Portfolio Store
              <% end %>
            </div>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
              <%= link_to products_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('home', size: 12, class_name: "mr-2") %>
                商品一覧
              <% end %>
              <%= link_to cart_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('shopping-cart', size: 12, class_name: "mr-2") %>
                カート
              <% end %>
              <%= link_to orders_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors" do %>
                <%= icon('user', size: 12, class_name: "mr-2") %>
                注文履歴
              <% end %>
            </div>
          </div>
          
          <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-4">
            <% if user_signed_in? %>
              <div class="relative">
                <button class="text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center" onclick="toggleDropdown()">
                  <%= current_user.full_name %>
                  <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <div id="userDropdown" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50">
                  <%= link_to edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    プロフィール
                  <% end %>
                  <div class="border-t border-gray-100"></div>
                  <%= link_to destroy_user_session_path, method: :delete, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" do %>
                    ログアウト
                  <% end %>
                </div>
              </div>
            <% else %>
              <%= link_to "ログイン", new_user_session_path, class: "text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
              <%= link_to "新規登録", new_user_registration_path, class: "bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors" %>
            <% end %>
          </div>
          
          <!-- Mobile menu button -->
          <div class="sm:hidden flex items-center">
            <button class="text-gray-300 hover:text-white p-2" onclick="toggleMobileMenu()">
              <%= icon('bars-3', size: 24) %>
            </button>
          </div>
        </div>
        
        <!-- Mobile menu -->
        <div id="mobileMenu" class="hidden sm:hidden">
          <div class="pt-2 pb-3 space-y-1">
            <%= link_to products_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('home', size: 12, class_name: "mr-2") %>
              商品一覧
            <% end %>
            <%= link_to cart_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('shopping-cart', size: 12, class_name: "mr-2") %>
              カート
            <% end %>
            <%= link_to orders_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium flex items-center" do %>
              <%= icon('user', size: 12, class_name: "mr-2") %>
              注文履歴
            <% end %>
          </div>
          <div class="pt-4 pb-3 border-t border-gray-700">
            <% if user_signed_in? %>
              <div class="px-3 py-2 text-base font-medium text-white">
                <%= current_user.full_name %>
              </div>
              <div class="mt-3 space-y-1">
                <%= link_to edit_user_registration_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium" do %>
                  プロフィール
                <% end %>
                <%= link_to destroy_user_session_path, method: :delete, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium" do %>
                  ログアウト
                <% end %>
              </div>
            <% else %>
              <%= link_to "ログイン", new_user_session_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium" %>
              <%= link_to "新規登録", new_user_registration_path, class: "text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-md mx-4 mt-4 flex items-center justify-between" role="alert">
        <div class="flex items-center">
          <%= icon('check', size: 12, class_name: "mr-2") %>
          <%= notice %>
        </div>
        <button type="button" class="text-green-400 hover:text-green-600" onclick="this.parentElement.style.display='none'">
          <%= icon('x-mark', size: 12) %>
        </button>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md mx-4 mt-4 flex items-center justify-between" role="alert">
        <div class="flex items-center">
          <%= icon('exclamation-triangle', size: 12, class_name: "mr-2") %>
          <%= alert %>
        </div>
        <button type="button" class="text-red-400 hover:text-red-600" onclick="this.parentElement.style.display='none'">
          <%= icon('x-mark', size: 12) %>
        </button>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h5 class="text-lg font-semibold mb-4">EC Portfolio Store</h5>
            <p class="text-gray-300">Rails 8で構築されたポートフォリオ用ECサイトです。</p>
          </div>
          <div>
            <h5 class="text-lg font-semibold mb-4">技術スタック</h5>
            <ul class="space-y-2 text-gray-300">
              <li>Ruby on Rails 8</li>
              <li>PostgreSQL</li>
              <li>Tailwind CSS</li>
              <li>Devise</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400">
          <p>&copy; 2024 EC Portfolio Store. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      function toggleDropdown() {
        const dropdown = document.getElementById('userDropdown');
        dropdown.classList.toggle('hidden');
      }

      function toggleMobileMenu() {
        const menu = document.getElementById('mobileMenu');
        menu.classList.toggle('hidden');
      }

      // Close dropdown when clicking outside
      document.addEventListener('click', function(event) {
        const dropdown = document.getElementById('userDropdown');
        const button = event.target.closest('button');
        if (dropdown && !dropdown.contains(event.target) && !button) {
          dropdown.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>
