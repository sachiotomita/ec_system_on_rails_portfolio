<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="max-w-md mx-auto">
    <div class="card">
      <div class="card-body p-8">
        <div class="text-center">
          <h2 class="text-3xl font-bold text-gray-900 mb-2">ログイン</h2>
          <p class="text-gray-600">アカウントにログインしてください</p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-6" }) do |f| %>
          <div class="space-y-4">
            <div>
              <%= f.label :email, "メールアドレス", class: "form-label" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", required: true %>
            </div>

            <div>
              <%= f.label :password, "パスワード", class: "form-label" %>
              <%= f.password_field :password, autocomplete: "current-password", class: "form-input", required: true %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="flex items-center">
                <%= f.check_box :remember_me, class: "h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" %>
                <%= f.label :remember_me, "ログイン状態を保持する", class: "ml-2 block text-sm text-gray-900" %>
              </div>
            <% end %>
          </div>

          <div>
            <%= f.submit "ログイン", class: "btn-primary btn-lg w-full flex justify-center" %>
          </div>
        <% end %>

        <div class="mt-6">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
