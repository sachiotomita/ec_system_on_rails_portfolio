<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card shadow">
      <div class="card-body p-5">
        <h2 class="text-center mb-4">プロフィール編集</h2>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "needs-validation", novalidate: true }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :first_name, "姓", class: "form-label" %>
              <%= f.text_field :first_name, autofocus: true, class: "form-control", required: true %>
            </div>
            <div class="col-md-6 mb-3">
              <%= f.label :last_name, "名", class: "form-label" %>
              <%= f.text_field :last_name, class: "form-control", required: true %>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :email, "メールアドレス", class: "form-label" %>
            <%= f.email_field :email, autocomplete: "email", class: "form-control", required: true %>
          </div>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="alert alert-info">
              確認待ち: <%= resource.unconfirmed_email %>
            </div>
          <% end %>

          <hr class="my-4">
          <h5 class="mb-3">パスワード変更</h5>

          <div class="mb-3">
            <%= f.label :password, "新しいパスワード", class: "form-label" %>
            <small class="form-text text-muted">（変更しない場合は空白のまま）</small>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
            <% if @minimum_password_length %>
              <small class="form-text text-muted"><%= @minimum_password_length %>文字以上</small>
            <% end %>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :current_password, "現在のパスワード", class: "form-label" %>
            <small class="form-text text-muted">（変更を確認するために必要）</small>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", required: true %>
          </div>

          <div class="d-grid">
            <%= f.submit "更新", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>

        <hr class="my-4">
        <h5 class="mb-3 text-danger">アカウント削除</h5>
        <p class="text-muted">アカウントを削除しますか？この操作は取り消せません。</p>
        <%= button_to "アカウントを削除", registration_path(resource_name), 
                      data: { confirm: "本当にアカウントを削除しますか？", turbo_confirm: "本当にアカウントを削除しますか？" }, 
                      method: :delete, 
                      class: "btn btn-outline-danger" %>

        <div class="text-center mt-4">
          <%= link_to "戻る", :back, class: "btn btn-secondary" %>
        </div>
      </div>
    </div>
  </div>
</div>
