<div class="row">
  <div class="col-12">
    <h1 class="mb-4">ショッピングカート</h1>
    
    <% if @cart_items.any? %>
      <div class="row">
        <div class="col-md-8">
          <% @cart_items.each do |item| %>
            <div class="card mb-3">
              <div class="card-body">
                <div class="row align-items-center">
                  <div class="col-md-2">
                    <% if item.product.primary_image %>
                      <%= image_tag item.product.primary_image.image, class: "img-fluid rounded", style: "height: 80px; object-fit: cover;" %>
                    <% else %>
                      <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 80px;">
                        <span class="text-muted small">画像なし</span>
                      </div>
                    <% end %>
                  </div>
                  
                  <div class="col-md-4">
                    <h6 class="card-title"><%= item.product.name %></h6>
                    <p class="text-muted small"><%= item.product.category.name %></p>
                  </div>
                  
                  <div class="col-md-2">
                    <span class="fw-bold">¥<%= number_with_delimiter(item.product.current_price) %></span>
                  </div>
                  
                  <div class="col-md-2">
                    <%= form_with url: cart_update_item_path, method: :patch, local: true, class: "d-flex" do |f| %>
                      <%= f.hidden_field :product_id, value: item.product.id %>
                      <%= f.number_field :quantity, value: item.quantity, min: 1, max: item.product.stock_quantity, class: "form-control form-control-sm" %>
                      <%= f.submit "更新", class: "btn btn-outline-primary btn-sm ms-1" %>
                    <% end %>
                  </div>
                  
                  <div class="col-md-1">
                    <span class="fw-bold">¥<%= number_with_delimiter(item.total_price) %></span>
                  </div>
                  
                  <div class="col-md-1">
                    <%= link_to cart_remove_item_path(product_id: item.product.id), method: :delete, 
                                class: "btn btn-outline-danger btn-sm", 
                                data: { confirm: "この商品をカートから削除しますか？" } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
          
          <div class="d-flex justify-content-between">
            <%= link_to "買い物を続ける", products_path, class: "btn btn-outline-secondary" %>
            <%= link_to "カートを空にする", cart_clear_path, method: :delete, 
                        class: "btn btn-outline-danger", 
                        data: { confirm: "カートを空にしますか？" } %>
          </div>
        </div>
        
        <div class="col-md-4">
          <div class="card">
            <div class="card-header">
              <h5 class="mb-0">注文合計</h5>
            </div>
            <div class="card-body">
              <div class="d-flex justify-content-between mb-2">
                <span>小計:</span>
                <span>¥<%= number_with_delimiter(@cart.total_price) %></span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span>送料:</span>
                <span>¥<%= number_with_delimiter(@cart.total_price >= 5000 ? 0 : 500) %></span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span>消費税:</span>
                <span>¥<%= number_with_delimiter((@cart.total_price * 0.1).round) %></span>
              </div>
              <hr>
              <div class="d-flex justify-content-between mb-3">
                <span class="fw-bold">合計:</span>
                <span class="fw-bold">¥<%= number_with_delimiter((@cart.total_price * 1.1 + (@cart.total_price >= 5000 ? 0 : 500)).round) %></span>
              </div>
              
              <%= link_to "レジに進む", new_order_path, class: "btn btn-primary btn-lg w-100" %>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center py-5">
        <h3 class="text-muted">カートが空です</h3>
        <p class="text-muted">商品をカートに追加してください。</p>
        <%= link_to "商品一覧を見る", products_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
