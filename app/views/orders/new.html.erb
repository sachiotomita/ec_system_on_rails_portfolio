<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">注文確認</h1>
  
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- 注文商品 -->
    <div class="lg:col-span-2">
      <div class="card mb-6">
        <div class="card-header">
          <h2 class="text-xl font-semibold text-gray-900">注文商品</h2>
        </div>
        <div class="card-body">
          <% @cart.cart_items.each do |item| %>
            <div class="flex items-center space-x-4 py-4 border-b border-gray-200 last:border-b-0">
              <div class="flex-shrink-0">
                <% if item.product.primary_image %>
                  <%= image_tag item.product.primary_image.image, class: "w-16 h-16 object-cover rounded-lg" %>
                <% else %>
                  <div class="w-16 h-16 bg-gray-100 rounded-lg flex items-center justify-center">
                    <span class="text-gray-400 text-xs">画像なし</span>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-medium text-gray-900"><%= item.product.name %></h3>
                <p class="text-sm text-gray-500"><%= item.product.category.name %></p>
              </div>
              <div class="flex items-center space-x-4">
                <span class="text-sm text-gray-900">¥<%= number_with_delimiter(item.product.current_price, precision: 0) %></span>
                <span class="text-sm text-gray-500">×<%= item.quantity %></span>
                <span class="font-semibold text-gray-900">¥<%= number_with_delimiter(item.total_price, precision: 0) %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- 配送先情報フォーム -->
      <div class="card">
        <div class="card-header">
          <h2 class="text-xl font-semibold text-gray-900">配送先情報</h2>
        </div>
        <div class="card-body">
          <% if user_signed_in? %>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">氏名</label>
                <p class="text-gray-900"><%= current_user.full_name %></p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">住所</label>
                <p class="text-gray-900"><%= current_user.address %></p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">電話番号</label>
                <p class="text-gray-900"><%= current_user.phone %></p>
              </div>
              <div>
                <%= link_to "プロフィールを編集", edit_user_registration_path, class: "btn-outline btn-sm" %>
              </div>
            </div>
          <% else %>
            <div class="space-y-4">
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                <div class="flex items-center">
                  <%= icon('information-circle', size: 12, class_name: "text-blue-600 mr-2") %>
                  <p class="text-sm text-blue-800">ゲスト注文の場合は、以下の情報を入力してください</p>
                </div>
              </div>
              
              <%= form_with model: @order, local: true, class: "space-y-4" do |f| %>
                <div>
                  <%= f.label :guest_name, "お名前", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.text_field :guest_name, class: "form-input w-full", placeholder: "山田太郎" %>
                </div>
                
                <div>
                  <%= f.label :guest_email, "メールアドレス", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.email_field :guest_email, class: "form-input w-full", placeholder: "example@email.com" %>
                </div>
                
                <div>
                  <%= f.label :guest_phone, "電話番号", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.text_field :guest_phone, class: "form-input w-full", placeholder: "090-1234-5678" %>
                </div>
                
                <div>
                  <%= f.label :shipping_address, "配送先住所", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.text_area :shipping_address, class: "form-input w-full", rows: 3, placeholder: "〒123-4567&#10;東京都渋谷区..." %>
                </div>
                
                <div>
                  <%= f.label :billing_address, "請求先住所", class: "block text-sm font-medium text-gray-700 mb-1" %>
                  <%= f.text_area :billing_address, class: "form-input w-full", rows: 3, placeholder: "〒123-4567&#10;東京都渋谷区..." %>
                </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
    
    <!-- 注文合計 -->
    <div class="lg:col-span-1">
      <div class="card sticky top-8">
        <div class="card-header">
          <h2 class="text-xl font-semibold text-gray-900">注文合計</h2>
        </div>
        <div class="card-body">
          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-gray-600">小計:</span>
              <span class="text-gray-900">¥<%= number_with_delimiter(@cart.total_price, precision: 0) %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">送料:</span>
              <span class="text-gray-900">¥<%= number_with_delimiter(@cart.total_price >= 5000 ? 0 : 500, precision: 0) %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">消費税:</span>
              <span class="text-gray-900">¥<%= number_with_delimiter((@cart.total_price * 0.1).round, precision: 0) %></span>
            </div>
            <hr class="my-4">
            <div class="flex justify-between text-lg font-semibold">
              <span class="text-gray-900">合計:</span>
              <span class="text-gray-900">¥<%= number_with_delimiter((@cart.total_price * 1.1 + (@cart.total_price >= 5000 ? 0 : 500)).round, precision: 0) %></span>
            </div>
          </div>
          
          <% if user_signed_in? %>
            <%= form_with model: @order, local: true do |f| %>
              <%= f.submit "注文を確定する", class: "btn-primary btn-lg w-full mt-6" %>
            <% end %>
          <% else %>
            <%= form_with model: @order, local: true do |f| %>
              <%= f.submit "注文を確定する", class: "btn-primary btn-lg w-full mt-6" %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
