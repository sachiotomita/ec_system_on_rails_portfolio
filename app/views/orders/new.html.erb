<div class="row">
  <div class="col-12">
    <h1 class="mb-4">注文確認</h1>
    
    <div class="row">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">注文商品</h5>
          </div>
          <div class="card-body">
            <% @cart.cart_items.includes(:product).each do |item| %>
              <div class="row align-items-center mb-3">
                <div class="col-md-2">
                  <% if item.product.primary_image %>
                    <%= image_tag item.product.primary_image.image, class: "img-fluid rounded", style: "height: 60px; object-fit: cover;" %>
                  <% else %>
                    <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 60px;">
                      <span class="text-muted small">画像なし</span>
                    </div>
                  <% end %>
                </div>
                <div class="col-md-4">
                  <h6><%= item.product.name %></h6>
                  <small class="text-muted"><%= item.product.category.name %></small>
                </div>
                <div class="col-md-2">
                  <span>¥<%= number_with_delimiter(item.product.current_price, precision: 0) %></span>
                </div>
                <div class="col-md-2">
                  <span><%= item.quantity %>個</span>
                </div>
                <div class="col-md-2">
                  <span class="fw-bold">¥<%= number_with_delimiter(item.total_price, precision: 0) %></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
        
        <div class="card mt-4">
          <div class="card-header">
            <h5 class="mb-0">配送先情報</h5>
          </div>
          <div class="card-body">
            <p><strong>氏名:</strong> <%= current_user.full_name %></p>
            <p><strong>住所:</strong> <%= current_user.address %></p>
            <p><strong>電話番号:</strong> <%= current_user.phone %></p>
            <p><%= link_to "プロフィールを編集", edit_user_registration_path, class: "btn btn-outline-primary btn-sm" %></p>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">注文合計</h5>
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
              <span>小計:</span>
              <span>¥<%= number_with_delimiter(@cart.total_price, precision: 0) %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>送料:</span>
              <span>¥<%= number_with_delimiter(@cart.total_price >= 5000 ? 0 : 500, precision: 0) %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>消費税:</span>
              <span>¥<%= number_with_delimiter((@cart.total_price * 0.1).round, precision: 0) %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between mb-3">
              <span class="fw-bold">合計:</span>
              <span class="fw-bold">¥<%= number_with_delimiter((@cart.total_price * 1.1 + (@cart.total_price >= 5000 ? 0 : 500)).round, precision: 0) %></span>
            </div>
            
            <%= form_with model: @order, local: true do |f| %>
              <%= f.submit "注文を確定する", class: "btn btn-primary btn-lg w-100" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
