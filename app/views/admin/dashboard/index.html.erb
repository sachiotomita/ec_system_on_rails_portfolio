<% content_for :page_title, "ダッシュボード" %>

<!-- Statistics Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <div class="card">
    <div class="card-body">
      <div class="flex items-center">
        <div class="flex-1">
          <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">総商品数</p>
          <p class="text-3xl font-bold text-gray-900"><%= @total_products %></p>
        </div>
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
            <%= icon('home', size: 24, class_name: "text-primary-600") %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="flex items-center">
        <div class="flex-1">
          <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">総注文数</p>
          <p class="text-3xl font-bold text-gray-900"><%= @total_orders %></p>
        </div>
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
            <%= icon('user', size: 24, class_name: "text-green-600") %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="flex items-center">
        <div class="flex-1">
          <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">登録ユーザー数</p>
          <p class="text-3xl font-bold text-gray-900"><%= @total_users %></p>
        </div>
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
            <%= icon('user', size: 24, class_name: "text-blue-600") %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <div class="flex items-center">
        <div class="flex-1">
          <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">過去30日売上</p>
          <p class="text-3xl font-bold text-gray-900">¥<%= number_with_delimiter(@recent_sales) %></p>
        </div>
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
            <%= icon('star', size: 24, class_name: "text-yellow-600") %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
  <!-- Recent Orders -->
  <div class="lg:col-span-2">
    <div class="card">
      <div class="card-header">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900">最近の注文</h3>
          <%= link_to admin_orders_path, class: "btn-outline btn-sm flex items-center" do %>
            すべて見る
            <%= icon('arrow-right', size: 16, class_name: "ml-2") %>
          <% end %>
        </div>
      </div>
      <div class="card-body">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">注文番号</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">顧客名</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">金額</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ステータス</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">日時</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @recent_orders.each do |order| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <%= link_to order.order_number, admin_order_path(order), class: "text-primary-600 hover:text-primary-900 font-medium" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= order.user.full_name %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">¥<%= number_with_delimiter(order.total_amount) %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="badge-<%= case order.status
                      when 'pending' then 'warning'
                      when 'processing' then 'info'
                      when 'shipped' then 'primary'
                      when 'delivered' then 'success'
                      when 'cancelled' then 'danger'
                      else 'secondary'
                    end %>">
                      <%= case order.status
                        when 'pending' then '注文受付中'
                        when 'processing' then '処理中'
                        when 'shipped' then '発送済み'
                        when 'delivered' then '配送完了'
                        when 'cancelled' then 'キャンセル'
                        else order.status
                      end %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= order.created_at.strftime("%m/%d %H:%M") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Low Stock Products -->
  <div class="lg:col-span-1">
    <div class="card">
      <div class="card-header">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900">在庫不足商品</h3>
          <%= link_to admin_products_path(status: 'low_stock'), class: "btn-outline btn-sm flex items-center" do %>
            すべて見る
            <%= icon('arrow-right', size: 16, class_name: "ml-2") %>
          <% end %>
        </div>
      </div>
      <div class="card-body">
        <% if @low_stock_products.any? %>
          <div class="space-y-4">
            <% @low_stock_products.each do |product| %>
              <div class="flex items-center space-x-3">
                <div class="flex-shrink-0">
                  <% if product.primary_image %>
                    <%= image_tag product.primary_image.image, class: "w-10 h-10 rounded-lg object-cover" %>
                  <% else %>
                    <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center">
                      <%= icon('home', size: 12, class_name: "text-gray-400") %>
                    </div>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-gray-900 truncate"><%= product.name.truncate(20) %></p>
                  <p class="text-xs text-gray-500">在庫: <%= product.stock_quantity %>個</p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mx-auto mb-4">
              <%= icon('check', size: 24, class_name: "text-gray-400") %>
            </div>
            <p class="text-gray-500 text-sm">在庫不足の商品はありません</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="card">
  <div class="card-header">
    <h3 class="text-lg font-semibold text-gray-900">クイックアクション</h3>
  </div>
  <div class="card-body">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <%= link_to new_admin_product_path, class: "btn-primary flex items-center justify-center p-4 hover:shadow-lg transition-shadow" do %>
        <%= icon('home', size: 24, class_name: "mr-3") %>
        商品を追加
      <% end %>
      
      <%= link_to new_admin_category_path, class: "btn-success flex items-center justify-center p-4 hover:shadow-lg transition-shadow" do %>
        <%= icon('tag', size: 24, class_name: "mr-3") %>
        カテゴリを追加
      <% end %>
      
      <%= link_to admin_orders_path, class: "btn-info flex items-center justify-center p-4 hover:shadow-lg transition-shadow" do %>
        <%= icon('user', size: 24, class_name: "mr-3") %>
        注文を確認
      <% end %>
      
      <%= link_to root_path, class: "btn-secondary flex items-center justify-center p-4 hover:shadow-lg transition-shadow" do %>
        <%= icon('shopping-cart', size: 24, class_name: "mr-3") %>
        ストアフロント
      <% end %>
    </div>
  </div>
</div>
